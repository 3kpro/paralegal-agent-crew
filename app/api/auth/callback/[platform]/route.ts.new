import { NextRequest, NextResponse } from 'next/server'
import { createClient } from '@/lib/supabase/server'

export async function GET(request: NextRequest) {
  try {
    const platform = request.nextUrl.pathname.split('/').pop()!
    const { searchParams } = new URL(request.url)
    const code = searchParams.get('code')
    const state = searchParams.get('state')
    const error = searchParams.get('error')

    // Extract campaign ID from state
    const [, campaignId] = state?.split('_') || []
    
    if (error || !code) {
      return NextResponse.redirect(`${process.env.NEXT_PUBLIC_APP_URL}/campaigns/${campaignId}?error=auth_failed`)
    }

    // Exchange code for tokens
    const tokens = await exchangeToken(platform, code)
    
    // Store in Supabase
    const supabase = await createClient()
    await supabase.from('social_accounts').upsert({
      platform: platform,
      access_token: tokens.access_token,
      refresh_token: tokens.refresh_token,
      token_expires_at: new Date(Date.now() + tokens.expires_in * 1000),
      is_active: true
    })

    // Redirect back to campaign with success
    return NextResponse.redirect(
      `${process.env.NEXT_PUBLIC_APP_URL}/campaigns/${campaignId}?connected=${platform}`
    )

  } catch (error) {
    console.error('OAuth callback error:', error)
    return NextResponse.redirect(
      `${process.env.NEXT_PUBLIC_APP_URL}/error?message=Connection failed`
    )
  }
}

async function exchangeToken(platform: string, code: string) {
  const clientId = platform === 'tiktok' 
    ? process.env.TIKTOK_CLIENT_KEY 
    : process.env.TWITTER_CLIENT_ID

  const clientSecret = platform === 'tiktok'
    ? process.env.TIKTOK_CLIENT_SECRET
    : process.env.TWITTER_CLIENT_SECRET

  const tokenUrl = platform === 'tiktok'
    ? 'https://open-api.tiktok.com/oauth/access_token/'
    : 'https://api.twitter.com/2/oauth2/token'

  const response = await fetch(tokenUrl, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/x-www-form-urlencoded'
    },
    body: new URLSearchParams({
      code,
      client_id: clientId!,
      client_secret: clientSecret!,
      grant_type: 'authorization_code',
      redirect_uri: `${process.env.NEXT_PUBLIC_APP_URL}/api/auth/callback/${platform}`
    })
  })

  if (!response.ok) {
    throw new Error('Token exchange failed')
  }

  return response.json()
}