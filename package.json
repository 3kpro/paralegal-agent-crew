{
  "name": "3kpro-services",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "docker:build": "docker build -t content-cascade-ai .",
    "docker:run": "docker run -p 3000:3000 content-cascade-ai",
    "deploy:local": "docker-compose up -d",
    "deploy:prod": "docker-compose -f docker-compose.prod.yml up -d",
    "logs": "docker-compose logs -f",
    "stop": "docker-compose down",
    "restart": "docker-compose restart",
    "healthcheck": "curl -f http://content-cascade-ai:3000/api/health || exit 1",
    "prepare": "husky"
  },
  "dependencies": {
    "@21st-extension/react": "^0.5.14",
    "@21st-extension/toolbar-next": "^0.5.14",
    "@google/generative-ai": "^0.24.1",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.78.0",
    "@types/node": "^20.19.24",
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.3.7",
    "@vercel/analytics": "^1.5.0",
    "autoprefixer": "^10.4.16",
    "axios": "^1.13.1",
    "framer-motion": "^12.23.24",
    "google-trends-api": "^4.9.2",
    "ioredis": "^5.8.2",
    "lucide-react": "^0.552.0",
    "motion": "^12.23.24",
    "next": "^15.5.6",
    "postcss": "^8.4.32",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "stripe": "^17.7.0",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/css": "^0.14.0",
    "@eslint/js": "^9.38.0",
    "@eslint/json": "^0.13.2",
    "@eslint/markdown": "^7.5.0",
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^30.0.0",
    "crypto-browserify": "^3.12.1",
    "eslint": "^9.39.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^16.2.6",
    "pg": "^8.16.3",
    "typescript-eslint": "^8.46.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  }
}
