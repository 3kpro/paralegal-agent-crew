# Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# Contact Form Integration
NEXT_PUBLIC_CONTACT_WEBHOOK_URL=https://your-n8n-webhook-url.com/webhook/contact

# Analytics (Optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# API Configuration
API_BASE_URL=https://api.3kproservices.com
API_KEY=your-api-key-here

# Database (if needed)
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# Email Service (if needed)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Anthropic API (for Claude AI)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# n8n Configuration
# Use n8n workflow (recommended for development/testing)
N8N_WEBHOOK_URL=http://localhost:5678/webhook/twitter-demo
N8N_BASE_URL=http://localhost:5678
USE_ANTHROPIC_DIRECT=false

# Production n8n URLs (when deploying)
# N8N_WEBHOOK_URL=https://n8n.your-domain.com/webhook/twitter-demo
# N8N_BASE_URL=https://n8n.your-domain.com

# Node Environment
NODE_ENV=development